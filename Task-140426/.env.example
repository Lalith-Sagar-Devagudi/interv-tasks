# ── OpenRouter (LLMs + Embeddings) ───────────────────────────────────────────
# Single key for all model calls — LLMs via /chat/completions,
# embeddings via /embeddings. Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
# Create a free cluster at https://cloud.qdrant.io
QDRANT_URL=https://your-cluster-id.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Model overrides (optional) ────────────────────────────────────────────────
# Verify exact slugs at https://openrouter.ai/models
RAG_MODEL=google/gemma-4-31b-it        # Approach 1 — Traditional RAG
AGENT_MODEL=deepseek/deepseek-v3-2-5   # Approach 2 — Agentic RAG
EMBEDDING_MODEL=qwen/qwen3-embedding-8b # Embeddings — 4096-dim vectors
